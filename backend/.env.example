MONGODB_URI=
JWT_SECRET=
PORT=5000
# Comma-separated list. Works for local + deployed frontend.
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173,https://auto-verse-omega.vercel.app

# Used for password reset links.
# In production (Render), set FRONTEND_URL=https://auto-verse-omega.vercel.app in Render env vars.
FRONTEND_URL=http://localhost:8080

# MongoDB driver options (useful for network issues)
# Set to 4 to force IPv4 if IPv6 causes connect timeouts
# MONGO_FAMILY=4
# MONGO_SERVER_SELECTION_TIMEOUT_MS=10000
# MONGO_CONNECT_TIMEOUT_MS=10000

# SMTP (for forgot/reset password emails)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# Admin seeding (used by `npm run seed:admin`)
# ADMIN_EMAIL=
# ADMIN_NAME=
# ADMIN_PASSWORD=

# Cloudinary (vehicle image uploads)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# Optional: override default folder "autoverse/vehicles"
# CLOUDINARY_FOLDER=

# Optional: public base URL for backend (used for local image URLs)
# BACKEND_PUBLIC_URL=http://localhost:5000
